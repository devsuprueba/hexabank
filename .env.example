### Hexabank example environment variables (do NOT commit secrets)
# Copy this to .env and fill real credentials

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/hexabank
SPRING_DATASOURCE_USERNAME=hexabank
SPRING_DATASOURCE_PASSWORD=changeme

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SPRING_KAFKA_CONSUMER_GROUP_ID=ms-client-group

# App and profiles
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8081
