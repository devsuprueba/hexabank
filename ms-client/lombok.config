# Lombok configuration for ms-client
# Prevent this config from bubbling up to parent folders
config.stopBubbling = true

# Add lombok-generated annotation to help tools ignore generated code
lombok.addLombokGeneratedAnnotation = true

# Keep lombok compatible with IDEs and tools
lombok.disableVersionChecks = false

# Prefer explicit getters/setters instead of @Data on entities (enforced by team rules)
# This is a documentation hint for developers; the team should avoid @Data on entities.
